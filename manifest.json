{
  "manifest_version": 3,
  "name": "AI Review Responder",
  "version": "1.0.0",
  "description": "Generate AI responses to reviews on any platform with one click",
  
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  
  "permissions": [
    "storage",
    "activeTab"
  ],
  
  "host_permissions": [
    "https://*.facebook.com/*",
    "https://*.google.com/*",
    "https://*.twitter.com/*",
    "https://*.instagram.com/*",
    "https://*.yelp.com/*",
    "https://*.tripadvisor.com/*",
    "https://responder.aiinfra.work/*"
  ],
  
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "AI Review Responder"
  },
  
  "content_scripts": [
    {
      "matches": [
        "https://*.facebook.com/*",
        "https://*.google.com/*",
        "https://*.twitter.com/*",
        "https://*.instagram.com/*",
        "https://*.yelp.com/*",
        "https://*.tripadvisor.com/*",
        "<all_urls>"
      ],
      "js": [
        "utils.js",
        "platforms/facebook.js",
        "platforms/google.js",
        "platforms/twitter.js",
        "platforms/instagram.js",
        "platforms/yelp.js",
        "content.js"
      ],
      "css": ["styles/popup.css"]
    }
  ],
  
  "background": {
    "service_worker": "background.js"
  },
  
  "options_page": "options.html",
  
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+R",
        "mac": "Command+Shift+R"
      },
      "description": "Open AI Review Responder"
    }
  }
}
