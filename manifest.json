{
  "manifest_version": 3,
  "name": "AI Review Responder",
  "version": "1.0.0",
  "description": "Generate AI responses to reviews on any platform with one click",
  "homepage_url": "https://responder.aiinfra.work",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "activeTab",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://*.facebook.com/*",
    "https://*.google.com/*",
    "https://*.twitter.com/*",
    "https://*.instagram.com/*",
    "https://*.yelp.com/*",
    "https://*.tripadvisor.com/*",
    "https://*.amazon.com/*",
    "https://*.amazon.co.uk/*",
    "https://*.amazon.de/*",
    "https://*.amazon.fr/*",
    "https://*.amazon.co.jp/*",
    "https://*.amazon.in/*",
    "https://*.amazon.ca/*",
    "https://*.amazon.com.mx/*",
    "https://*.amazon.com.au/*",
    "https://*.amazon.com.br/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "AI Review Responder"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.facebook.com/*",
        "https://*.google.com/*",
        "https://*.twitter.com/*",
        "https://*.instagram.com/*",
        "https://*.yelp.com/*",
        "https://*.tripadvisor.com/*",
        "https://*.amazon.com/*",
        "https://*.amazon.co.uk/*",
        "https://*.amazon.de/*",
        "https://*.amazon.fr/*",
        "https://*.amazon.co.jp/*",
        "https://*.amazon.in/*",
        "https://*.amazon.ca/*",
        "https://*.amazon.com.mx/*",
        "https://*.amazon.com.au/*",
        "https://*.amazon.com.br/*"
      ],
      "js": [
        "utils.js",
        "platforms/facebook.js",
        "platforms/google.js",
        "platforms/twitter.js",
        "platforms/instagram.js",
        "platforms/yelp.js",
        "platforms/tripadvisor.js",
        "platforms/amazon.js",
        "content.js"
      ],
      "css": ["styles/popup.css"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "web_accessible_resources": [{
    "resources": ["platforms/amazon.js"],
    "matches": [
      "https://*.amazon.com/*",
      "https://*.amazon.co.uk/*",
      "https://*.amazon.de/*",
      "https://*.amazon.fr/*",
      "https://*.amazon.co.jp/*",
      "https://*.amazon.in/*",
      "https://*.amazon.ca/*",
      "https://*.amazon.com.mx/*",
      "https://*.amazon.com.au/*",
      "https://*.amazon.com.br/*"
    ]
  }],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+R",
        "mac": "Command+Shift+R"
      },
      "description": "Open AI Review Responder"
    }
  }
}
